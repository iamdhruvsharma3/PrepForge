generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum InterviewMode {
  text
  voice
}

enum InterviewStatus {
  initialized
  active
  completed
}

enum WorkspaceRole {
  owner
  admin
  member
}

enum ResumeParseStatus {
  completed
  needs_review
  failed
}

model Workspace {
  candidateProfiles CandidateProfile[]
  id                String            @id @default(cuid())
  createdAt         DateTime          @default(now())
  featureJson       Json?
  interviews        Interview[]
  members           WorkspaceMember[]
  name              String
  plan              String            @default("free")
  slug              String            @unique
  updatedAt         DateTime          @updatedAt
  activeUsers       User[]            @relation("ActiveWorkspace")
}

model User {
  candidateProfiles CandidateProfile[]
  id                String            @id
  activeWorkspaceId String?
  createdAt         DateTime          @default(now())
  email             String            @unique
  emailVerified     Boolean
  image             String?
  interviews        Interview[]
  memberships       WorkspaceMember[]
  name              String
  accounts          Account[]
  sessions          Session[]
  updatedAt         DateTime          @updatedAt
  activeWorkspace   Workspace?        @relation("ActiveWorkspace", fields: [activeWorkspaceId], references: [id], onDelete: SetNull)
}

model CandidateProfile {
  activeResumeDocument    ResumeDocument?  @relation("ActiveResumeDocument", fields: [activeResumeDocumentId], references: [id], onDelete: SetNull)
  activeResumeDocumentId  String?
  id               String           @id @default(cuid())
  createdAt        DateTime         @default(now())
  currentCompany   String?
  focusAreas       String[]
  headline         String?
  resumeDocuments  ResumeDocument[] @relation("ProfileResumeDocuments")
  resumeHighlights String[]
  strengths        String[]
  summary          String?
  targetRole       String?
  updatedAt        DateTime         @updatedAt
  userId           String
  workspaceId      String
  yearsExperience  Int?
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace        Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

model ResumeDocument {
  activeForProfiles  CandidateProfile[] @relation("ActiveResumeDocument")
  id                 String             @id @default(cuid())
  candidateProfileId String
  contentType        String?
  createdAt          DateTime           @default(now())
  fileName           String
  parseConfidence    Int?
  parserName         String             @default("prepforge-resume-parser")
  parserVersion      String             @default("0.1.0")
  parseStatus        ResumeParseStatus  @default(completed)
  parseWarnings      String[]
  rawText            String
  sizeBytes          Int?
  source             String             @default("paste")
  version            Int
  wordCount          Int
  candidateProfile   CandidateProfile   @relation("ProfileResumeDocuments", fields: [candidateProfileId], references: [id], onDelete: Cascade)

  @@unique([candidateProfileId, version])
}

model Interview {
  id                String             @id @default(cuid())
  answers           InterviewAnswer[]
  company           String?
  completedAt       DateTime?
  createdAt         DateTime           @default(now())
  difficulty        String
  firstQuestion     String
  mode              InterviewMode
  role              String
  status            InterviewStatus    @default(initialized)
  updatedAt         DateTime           @updatedAt
  userId            String
  workspaceId       String
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace         Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model InterviewAnswer {
  id                 String    @id @default(cuid())
  communicationScore Int
  correctnessScore   Int
  createdAt          DateTime  @default(now())
  depthScore         Int
  feedback           String
  interviewId        String
  nextQuestion       String?
  orderIndex         Int
  prompt             String
  response           String
  interview          Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  @@unique([interviewId, orderIndex])
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  createdAt   DateTime      @default(now())
  role        WorkspaceRole @default(member)
  updatedAt   DateTime      @updatedAt
  userId      String
  workspaceId String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

model Session {
  id          String   @id
  createdAt   DateTime @default(now())
  expiresAt   DateTime
  ipAddress   String?
  token       String   @unique
  updatedAt   DateTime @updatedAt
  userAgent   String?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id
  accessToken           String?
  accessTokenExpiresAt  DateTime?
  accountId             String
  createdAt             DateTime  @default(now())
  idToken               String?
  password              String?
  providerId            String
  refreshToken          String?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  tokenType             String?
  updatedAt             DateTime  @updatedAt
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
}

model Verification {
  id         String   @id
  createdAt  DateTime @default(now())
  expiresAt  DateTime
  identifier String
  updatedAt  DateTime @updatedAt
  value      String
}
